rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Rules for the Products collection
    match /products/{productId} {
      allow read: if true; // Public can view products
      // Only admins can create or delete products
      allow create, delete: if isAdmin();
      // Admins can update anything. Public can only decrement stockQty and touch updatedAt.
      allow update: if isAdmin()
        || (
             request.resource.data.stockQty < resource.data.stockQty
          && request.resource.data.stockQty >= 0
          && request.writeFields.hasOnly(['stockQty', 'updatedAt'])
        );
    }

    // Rules for the Orders collection
    match /orders/{orderId} {
      allow create: if true; // Public can place orders
      allow read, update, delete: if isAdmin(); // Only admins can manage orders
    }

    // Rules for the Admins collection (Private)
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK for security
    }
  }
}